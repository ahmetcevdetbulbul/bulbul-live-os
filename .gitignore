# --- Built ISO / images (large, not source) ---
*.iso
*.img
*.zsync*
binary.contents
binary.packages

# --- live-build working directories (regenerated by `lb build`) ---
binary/
chroot/
cache/
local/
.build/
chroot.headers
chroot.packages.install
chroot.packages.live

# --- live-build auto-generated config dumps (regenerated by ./auto/config) ---
/config/binary
/config/bootstrap
/config/chroot
/config/common
/config/source

# --- Session tooling / scratch artifacts (not part of the project) ---
.claude/
*.log
qemu-*.sh
serial_console.py
capture_screenshot.py

# --- Loose screenshots at repo root (curated copy lives in docs/) ---
/*.png
!docs/*.png
